<li class="list-group-item">
  <div class="d-flex">
    <div class="flex-shrink-0">
      <%= image_tag comment.author.avatar_image_url, class: "rounded-circle img-small me-2" %>
    </div>
    <div class="flex-grow-1 ms-3">
      <h6 class="mt-0 mb-1">
        <%= link_to comment.author.username, user_path(comment.author.username), class: "text-dark" %>
        <small class="text-muted"><%= time_ago_in_words(comment.created_at) %> ago</small>
      </h6>
      <p class="mb-1"><%= comment.body %></p>

      <% if current_user == comment.author %>
        <div class="mt-2">
          <%= link_to edit_comment_path(comment), class: "text-primary me-3" do %>
            <i class="fas fa-edit me-1"></i> Edit
          <% end %>
          
          <%= link_to comment_path(comment),
                      method: :delete,
                      data: { 
                        turbo_method: :delete, 
                        turbo_confirm: "Are you sure?" 
                      },
                      class: "text-danger" do %>
            <i class="fas fa-trash me-1"></i> Delete
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</li>
